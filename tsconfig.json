{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",

        "strict": true,

        "outDir": "./dist",
        "rootDir": "./src",

        "jsx": "react-jsx",

        "esModuleInterop": true,
        "skipLibCheck": true,

        "types": ["node", "jest"],

        "forceConsistentCasingInFileNames": true,
        "noUncheckedIndexedAccess": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["src", "bin"],
    "exclude": ["node_modules", "dist"]
}
